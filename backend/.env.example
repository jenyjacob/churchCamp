# ==============================================================================
# GCA Church Camp Backend - Environment Variables Template
# Copy this file to backend/.env and fill in real values. NEVER commit .env to git!
# ==============================================================================

# Backend Flask Configuration
FLASK_ENV=development
PORT=5000

# Database Connection URL (SQLite for local dev, MySQL for production EC2)
# Local SQLite example: sqlite:///churchcamp.db
# MySQL example: mysql+pymysql://db_user:db_password@localhost:3306/churchcamp
DATABASE_URL=sqlite:///churchcamp.db

# JWT & Application Signing Secrets (Use 32+ character random secret keys)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secure-jwt-secret-key-at-least-32-chars
SECRET_KEY=your-secure-flask-session-secret-key-at-least-32-chars

# CORS Allowed Origins (comma-separated list of trusted frontend origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Initial Admin Seed Credentials (used only on first database initialization)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=your-secure-seed-admin-password
SEED_ADMIN_EMAIL=admin@churchcamp.org

# WebAuthn / Passkeys Configuration
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=GCA Camp Manager
WEBAUTHN_RP_ORIGIN=http://localhost:3000
